    "axios": "^1.17.0",
    "better-sqlite3": "^9.4.3",
    "cors": "^2.8.6",
    "cosine-similarity": "^1.0.1",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "sharp": "0.33.5"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
